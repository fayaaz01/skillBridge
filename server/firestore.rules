rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isOwner(ownerId) { return isSignedIn() && ownerId == uid(); }

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /profiles/{userId}/keys/{doc} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == uid();
      allow update, delete: if isSignedIn() && resource.data.ownerId == uid();
    }

    match /matches/{matchId} {
      // Server-only writes; users can read if involved via listing ownership
      allow write: if false;
      allow read: if isSignedIn();
    }

    match /conversations/{convoId} {
      allow read, write: if isSignedIn() && (uid() in resource.data.participantIds || uid() in request.resource.data.participantIds);
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && (uid() in get(/databases/$(database)/documents/conversations/$(convoId)).data.participantIds);
        allow update, delete: if false; // immutable messages
      }
    }

    match /ratings/{ratingId} {
      allow create: if isSignedIn() && request.resource.data.raterId == uid();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    match /endorsements/{endorsementId} {
      allow create: if isSignedIn() && request.resource.data.endorserId == uid();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    match /intros/{introId} {
      allow create, update, delete: if isSignedIn() && request.resource.data.userId == uid();
      allow read: if isSignedIn();
    }

    match /introRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.requesterId == uid();
      allow read: if isSignedIn() && (resource.data.requesterId == uid() || resource.data.targetUserId == uid());
      allow update: if isSignedIn() && (resource.data.targetUserId == uid());
      allow delete: if false;
    }
  }
}
